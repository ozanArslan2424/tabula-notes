datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  USER
  ADMIN
}

model Account {
  id           String    @id
  provider     String
  providerId   String
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String

  @@unique([provider, providerId])
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
}

model User {
  id             String          @id
  username       String?
  email          String?         @unique
  password       String?
  image          String?
  googleId       String?         @unique
  githubId       String?         @unique
  emailVerified  Boolean         @default(false)
  role           UserRole        @default(USER)
  accounts       Account[]
  sessions       Session[]
  registerTokens RegisterToken[]
  books          Book[]
  quicknotes     QuickNote[]
  bugs           Bug[]
}

model RegisterToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime
  User    User?    @relation(fields: [userId], references: [id])
  userId  String?

  @@unique([email, token])
}

model Book {
  id          String   @id @default(uuid())
  title       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  hasTasks    Boolean  @default(false)
  groups      Group[]
  tasks       Task[]
  User        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
}

model Task {
  id        Int      @id @default(autoincrement())
  name      String
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  Book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  bookId    String
}

model QuickNote {
  id      Int    @id @default(autoincrement())
  content String
  User    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId  String
}

model Group {
  id        Int      @id @default(autoincrement())
  title     String
  createdAt DateTime @default(now())
  notes     Note[]
  Book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  bookId    String
}

model Note {
  id        Int      @id @default(autoincrement())
  content   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  Group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId   Int
}

model Bug {
  id          Int      @id @default(autoincrement())
  subject     String
  description String
  createdAt   DateTime @default(now())
  User        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  resolved    Boolean  @default(false)
}
